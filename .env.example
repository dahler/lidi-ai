# ── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ── Google OAuth ─────────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth (optional, legacy) ──────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ── LLM Provider ─────────────────────────────────────────────────────
# "ollama" = local Ollama  |  "deepseek" = DeepSeek cloud API
AI_PROVIDER=ollama

# ── DeepSeek (used when AI_PROVIDER=deepseek) ────────────────────────
# Get your key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# deepseek-chat (V3, fast) or deepseek-reasoner (R1, smarter)
DEEPSEEK_MODEL=deepseek-chat

# ── Embedding Provider ────────────────────────────────────────────────
# "ollama" = local nomic-embed-text (768 dims)
# "openai" = OpenAI text-embedding-3-small (1536 dims)
EMBEDDING_PROVIDER=ollama

# ── OpenAI Embeddings (used when EMBEDDING_PROVIDER=openai) ──────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# IMPORTANT: set RAG_EMBEDDING_DIM to match your model:
#   text-embedding-3-small  → 1536
#   text-embedding-3-large  → 3072
#   text-embedding-ada-002  → 1536
RAG_EMBEDDING_DIM=768

# ── Ollama (used when AI_PROVIDER=ollama or EMBEDDING_PROVIDER=ollama)
OLLAMA_TEXT_MODEL=gemma3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Tavily web search (optional) ─────────────────────────────────────
TAVILY_API_KEY=

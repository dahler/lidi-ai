# Database (must match docker-compose.prod.yml DB_* values)
DATABASE_URL=postgresql+asyncpg://lidi:CHANGE_ME@db:5432/lidi_db
DB_USER=lidi
DB_PASSWORD=CHANGE_ME
DB_NAME=lidi_db

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# URLs
FRONTEND_URL=https://app.yourdomain.com
CORS_ORIGINS=["https://app.yourdomain.com","https://admin.yourdomain.com","https://widget.yourdomain.com"]
ANONYMOUS_SESSION_COOKIE=lidi_session

# AI provider
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
